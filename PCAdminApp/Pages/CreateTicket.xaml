<Window x:Class="PCAdminApp.Pages.CreateTicket"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:PCAdminApp.Pages"
        mc:Ignorable="d" WindowStartupLocation="CenterScreen" WindowStyle="None"
        Title="CreateTicket" Height="400" Width="400" Background="#262626" Foreground="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0">
            <Button Name="BtnCloseWindow" Click="BtnCloseWindow_Click"  Background="#363636" Margin="10" BorderThickness="0" HorizontalAlignment="Right">
                <materialDesign:PackIcon Kind="Close" Foreground="White"/>
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Vertical" VerticalAlignment="Center">
            <TextBlock Text="Создание тикета" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="DemiBold"/>
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="1">
                <StackPanel Orientation="Horizontal" Margin="0 5 0 0">
                    <materialDesign:PackIcon Kind="RemoteDesktop" VerticalAlignment="Center" Foreground="White"/>
                    <TextBlock Text="Название ПК" FontSize="14" Margin="5 0" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBox x:Name="TBPCName" HorizontalAlignment="Left" Padding="3" TextAlignment="Left" Width="200" >
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
                <StackPanel Orientation="Horizontal"  Margin="0 5">
                    <materialDesign:PackIcon Kind="FileDocumentError" Foreground="White" VerticalAlignment="Center" Height="19" Margin="-3 0"/>
                    <TextBlock Text="Описание тикета" FontSize="14" Margin="5 0" Foreground="White"/>
                </StackPanel>
                <TextBox Name="TBTicketDescripton" Width="200" TextWrapping="Wrap" Padding="3" TextAlignment="Left">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="CalendarOutline"  VerticalAlignment="Center" Height="19" Margin="-3 0" Foreground="White"/>
                    <TextBlock Text="Дата" VerticalAlignment="Center" FontSize="14" Margin="5 0" Foreground="White"/>
                </StackPanel>
                <DatePicker SelectedDate="{Binding SelectedDate}" LostFocus="DatePicker_LostFocus" Height="24"/>

            </StackPanel>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0 0 0 5" Grid.Row="2">
            <Button Content="Создать" Name="BtnCreateTicket" Padding="5" Click="BtnCreateTicket_Click"  Foreground="White" Background="#FB1B2A" BorderBrush="#BF131F">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        <Button Content="Отмена" Name="BtnCancel" Margin="5 0" Padding="5" Click="BtnCancel_Click" Foreground="White" Background="#FF353434">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Button.Resources>
        </Button>
        </StackPanel>
    </Grid>
</Window>
