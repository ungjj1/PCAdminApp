<Page x:Class="PCAdminApp.Pages.ComputersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PCAdminApp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ComputersPage">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnClients" Click="BtnClients_Click" Margin="10 0" Background="#3B3B3B" Foreground="White">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="PersonOutline" HorizontalAlignment="Center"/>
                        <TextBlock Text="Список клиентов" Margin="10 0"/>
                    </StackPanel>
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button x:Name="RegistrationClinet" Click="RegistrationClient_Click" Background="#3B3B3B" Foreground="White">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="PersonAddOutline" HorizontalAlignment="Center"/>
                        <TextBlock Text="Добавить клиента" Margin="10 0"/>
                    </StackPanel>
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Row="1">
            <ItemsControl ItemsSource="{Binding ComputersList}" Margin="10">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Gray" BorderThickness="1" Margin="5" Width="140" Background="#F4F4F4">
                            <StackPanel>
                                <Grid Background="#007ACC" Height="25">
                                    <TextBlock Text="{Binding PCName}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>

                                <Border Background="#28A745" Height="25">
                                    <TextBlock Text="{Binding Status.Name, FallbackValue='Свободен'}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                                </Border>

                                <Button Content="Сброс" Background="#D93846" Foreground="White" Margin="4,4,4,0" Height="24" BorderThickness="0" FontSize="10"/>

                                <StackPanel Margin="0,5">
                                    <TextBlock Text="-- мин" HorizontalAlignment="Center" FontSize="10"/>
                                    <TextBlock Text="00:00" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                </StackPanel>

                                <Grid Margin="4,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="White" BorderBrush="Silver" BorderThickness="1">
                                        <TextBlock Text="--.--" HorizontalAlignment="Center" FontSize="10"/>
                                    </Border>
                                    <Button Grid.Column="1" Background="#28A745" Foreground="White" Width="20" Height="20" Margin="2,0,0,0" BorderThickness="0" Content="💾"/>
                                </Grid>

                                <CheckBox Content="Посадка" Margin="5,2" FontSize="10"/>
                                <CheckBox Content="Бронь" Margin="5,2" FontSize="10"/>

                                <UniformGrid Columns="1" Margin="4,2">
                                    <Button Background="#D93846" Margin="0,1" Height="22" Content="⏻" Foreground="White"/>
                                    <Button Background="#28A745" Margin="0,1" Height="22" Content="⟳" Foreground="White"/>
                                </UniformGrid>

                                <Button Content="Тех.старт" Background="#333" Foreground="White" Margin="4,4,4,2" Height="24" BorderThickness="0" FontSize="10"/>

                                <Button Content="Заблокиро..." Margin="4,1" Height="22" BorderBrush="#D93846" Foreground="#D93846" Background="Transparent" FontSize="9"/>
                                <Button Content="Разблокир..." Margin="4,1" Height="22" BorderBrush="#28A745" Foreground="#28A745" Background="Transparent" FontSize="9"/>

                                <TextBlock Text="{Binding IpAddress}" HorizontalAlignment="Center" Margin="0,5" FontSize="9" Foreground="Gray"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            </ScrollViewer>
    </Grid>
</Page>
