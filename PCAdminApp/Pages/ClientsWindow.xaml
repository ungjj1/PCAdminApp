<Window x:Class="PCAdminApp.Pages.ClientsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PCAdminApp.Pages"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="ClientsWindow" Height="230" Width="600" WindowStartupLocation="CenterScreen" WindowStyle="None" Background="#262626">
    <Window.Resources>
        <Style TargetType="Border">
            <Setter Property="CornerRadius" Value="15"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Right" Grid.Row="0">
            <Button Name="BtnCloseWindow" Click="BtnCloseWindow_Click"  Background="#363636" Margin="10" BorderThickness="0">
                <materialDesign:PackIcon Kind="Close" Foreground="White"/>
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Поиск клиентов" Foreground="White" FontSize="16" FontWeight="Bold"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Left" Margin="100 0" VerticalAlignment="Center">
            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="PersonOutline" Foreground="White"/>
                    <TextBlock Text="Поиск клиента" Foreground="White"/>
                </StackPanel>
                <TextBox Name="TBClientSearch" Width="300" TextAlignment="Center" TextChanged="TBClientSearch_TextChanged">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
                <Popup Name="PopupSearchResults" 
               PlacementTarget="{Binding ElementName=TBClientSearch}"
               Placement="Bottom"
               StaysOpen="False"
               Width="{Binding ActualWidth, ElementName=TBClientSearch}">
                    <ListBox Name="ListBoxResults" 
                     SelectionChanged="ListBoxResults_SelectionChanged"
                     MaxHeight="200"
                     Background="White">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <TextBlock Text="{Binding FullName}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding PhoneNumber}" FontSize="11" Foreground="Gray"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Popup>
            </StackPanel>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Row="3" HorizontalAlignment="Right" Margin="30 15">
            <Button Name="BtnSelectClient" Click="BtnSelectClient_Click"  Content="Выбрать клиента" FontSize="10" Padding="5 0" BorderThickness="1" Background="#FB1B2A" BorderBrush="#BF131F" Foreground="White" FontWeight="SemiBold" Height="20">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="7"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>
