<Page x:Class="PCAdminApp.Pages.InventoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:local="clr-namespace:PCAdminApp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="InventoryPage">
    <Page.Resources>
        <DataTemplate x:Key="InventoryTemplate">
            <Border Margin="0 5" Padding="10" Height="140" BorderBrush="LightGray" BorderThickness="1" Background="Transparent" MouseLeftButtonUp="Border_MouseLeftButtonUp">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center" Margin="20 0 0 0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="RemoteDesktop" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ProfileName, StringFormat='Название конфигурации: {0}'}" FontSize="14" Margin="5 0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Cpu64Bit"/>
                            <TextBlock Text="{Binding CPU, StringFormat='Процессор: {0}'}" FontSize="14" Margin="5 0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="GraphicsProcessingUnit" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding GPU, StringFormat='Видеокарта: {0}'}" VerticalAlignment="Center" FontSize="14" Margin="5 0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Memory" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding RAM, StringFormat='Оперативная память: {0}'}" FontSize="14" Margin="5 0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="DeveloperBoard" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Motherboard, StringFormat='Материнская плата: {0}'}" FontSize="14" Margin="5 0"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBox Name="TBSearch" Width="200" Margin="5 0" Height="25" TextAlignment="Center" TextChanged="TBSearch_TextChanged">
                <TextBox.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </TextBox.Resources>
            </TextBox>
            <Button Name="BtnAddConfiguration" Click="BtnAddConfiguration_Click" Content="Добавить конфигурацию" Padding="5" Background="#FB1B2A" Foreground="White" FontWeight="DemiBold" BorderThickness="1" BorderBrush="#BF131F">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Row="1">
            <ItemsControl x:Name="InventoryList" ItemTemplate="{StaticResource InventoryTemplate}"/>
            </ScrollViewer>
    </Grid>
</Page>
