<Window x:Class="PCAdminApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PCAdminApp"
        mc:Ignorable="d"
        Title="CyberCore" Height="800" Width="1200" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Column="0" Grid.Row="0" Background="#262626" BorderThickness="0">
            <Image Source="/Resources/pcclublogo.png" Width="230" Margin="10 0"/>

            
        </Border>
        <Border Grid.Column="0" Grid.Row="1" Background="#262626">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <!-- Меню занимает всё доступное место -->
                    <RowDefinition Height="Auto"/>
                    <!-- Текст внизу -->
                </Grid.RowDefinitions>

                <!-- Контейнер с кнопками -->
                <StackPanel Grid.Row="0" Margin="0 20 0 0">
                    <Button Name="BtnComputers" Click="BtnComputers_Click" Style="{StaticResource MenuButtonStyle}" Width="250" Height="70" BorderThickness="0,2,0,2">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ElectricityOutline" VerticalAlignment="Center" HorizontalAlignment="Center" Height="30" Width="30"/>
                            <TextBlock Text="Панель управления устройствами" Width="160" TextWrapping="Wrap" FontSize="16"/>
                        </StackPanel>
                    </Button>
                    <Button Name="BtnTicket" Click="BtnTicket_Click" Style="{StaticResource MenuButtonStyle}" Width="250" Height="70">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <materialDesign:PackIcon Kind="ErrorOutline" VerticalAlignment="Center" Height="25" Width="25"/>
                            <TextBlock Text="Жалобы на гарнитуру" TextWrapping="Wrap" Margin="3 0" VerticalAlignment="Center" FontSize="16"/>
                        </StackPanel>
                    </Button>
                    <Button Name="BtnInventory" Click="BtnInventory_Click" Style="{StaticResource MenuButtonStyle}" Width="250" Height="70">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Width="200">
                            <materialDesign:PackIcon Kind="MouseOutline" VerticalAlignment="Center" Height="25" Width="25"/>
                            <TextBlock Text="Конфигурации ПК" TextWrapping="Wrap" Margin="3 0" VerticalAlignment="Center" FontSize="16"/>
                        </StackPanel>
                    </Button>
                    <Button Name="BtnReport" Click="BtnReport_Click" Style="{StaticResource MenuButtonStyle}" Width="250" Height="70">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Width="200">
                            <materialDesign:PackIcon Kind="BookOpenOutline" VerticalAlignment="Center" Height="25" Width="25"/>
                            <TextBlock Text="Отчеты" TextWrapping="Wrap" Margin="3 0" VerticalAlignment="Center" FontSize="16"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <TextBlock Grid.Row="1" x:Name="TBUserName"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="0,10,10,10"/>
            </Grid>
        </Border>
        <Border Grid.Column="1" Grid.Row="0" Background="#262626">
            <Grid Margin="20,0">
                <TextBlock x:Name="TxtPageTitle" VerticalAlignment="Center" 
                           FontSize="18" Foreground="White" FontWeight="SemiBold"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Name="TBRole" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Button Background="#262626" Foreground="White" Width="100" Height="30" Name="BtnExit" Click="BtnExit_Click" BorderThickness="0" Style="{StaticResource MenuButtonStyle}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <materialDesign:PackIcon Kind="Logout" VerticalAlignment="Center" Margin="0 2 0 0" Height="12" Width="12"/>
                            <TextBlock Text="Выйти" TextWrapping="Wrap" Margin="3 0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        <Frame Name="MainFrame" NavigationUIVisibility="Hidden" Grid.Column="1" Grid.Row="1" Margin="10"/>
    </Grid>
</Window>