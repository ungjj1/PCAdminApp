<Window x:Class="PCAdminApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PCAdminApp"
        mc:Ignorable="d"
        Title="Авторизация - CyberCore" Height="400" Width="500" Background="#262626" WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Image Source="/Resources/pcclublogo.png" Height="50"/>
            <StackPanel Orientation="Vertical" Margin="0 10">
                <TextBlock Text="Логин" Foreground="White" Margin="15 0"/>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="UserOutline" Foreground="White" Height="25"/>
                    <TextBox Name="TbUserLogin" Width="200" Height="25" FontSize="16"/>
                </StackPanel>
                <TextBlock Text="Пароль" Foreground="White" Margin="15 0"/>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="PasswordOutline" Foreground="White" Height="25"/>
                    <PasswordBox x:Name="TBUserPassword" Width="200" Height="25" FontSize="16"/>
                </StackPanel>
                <Button x:Name="BtnAuth" Click="BtnAuth_Click" Content="Войти" Margin="0 10" Height="30" Width="200" HorizontalAlignment="Center" Background="#FC202C" Foreground="White" FontWeight="Bold" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
